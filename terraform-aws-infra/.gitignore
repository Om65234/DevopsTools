# Terraform directories and files
**/.terraform/*
.terraform/
.terraform.tfstate.d/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files, which might contain sensitive data
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
tfplan
plan.out

# Keep the provider lock file tracked
!.terraform.lock.hcl

# IDE and editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db
*.tmp

# Log files
*.log
debug.log

# Dependencies
vendor/
